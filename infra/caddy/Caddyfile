# Caddy for the whole app. Auto-provisions Let's Encrypt TLS for each site.
# $SITE_DOMAIN = frontend apex (e.g. casaval.eu); $API_DOMAIN = api host.

# Frontend (Next.js)
{$SITE_DOMAIN} {
	encode gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
	reverse_proxy frontend:3000
}

# www -> apex
www.{$SITE_DOMAIN} {
	redir https://{$SITE_DOMAIN}{uri} permanent
}

# API
{$API_DOMAIN} {
	# Allow the 40MB image-upload batches (nginx used client_max_body_size 45m).
	request_body {
		max_size 45MB
	}

	# Security headers (Caddy already serves HTTPS + HSTS-eligible).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		-Server
	}

	reverse_proxy backend:8000 {
		# Caddy is the edge, so the immediate peer IS the real client. Expose it
		# as X-Real-IP, which the backend's _client_identifier trusts first for
		# rate limiting (spoof-resistant; the backend port is never published).
		header_up X-Real-IP {remote_host}
	}
}
