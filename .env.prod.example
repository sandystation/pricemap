# Production env for docker-compose.prod.yml. Copy to `.env` on the VM
# (chmod 600) and fill in. docker compose reads this file both for ${VAR}
# substitution (API_DOMAIN) and to pass env into the backend/worker containers.

# Domains Caddy serves + provisions TLS for. Point their DNS A records at the VM.
# SITE_DOMAIN = frontend apex (also serves www.<SITE_DOMAIN> -> apex redirect).
SITE_DOMAIN=casaval.eu
API_DOMAIN=api.casaval.eu

# Exact browser origins allowed by CORS. JSON list, https, no trailing slash.
# Include Vercel preview domains you test from, or gate testing to production.
CORS_ORIGINS=["https://casaval.eu","https://www.casaval.eu"]

# Gemini key for serve-time LLM enrichment (worker uses it). NEVER expose to browser.
# NOTE: this is the Gemini API key — distinct from GOOGLE_OAUTH_CLIENT_ID/SECRET (OAuth) below.
GOOGLE_API_KEY=AI...
LLM_PROVIDER=google
LLM_MODEL=gemini-3.1-flash-lite-preview

# --- Database (Auth.js user store on the `postgres` service) ---
POSTGRES_PASSWORD=change-me-strong-password
# Node/pg URL used by Auth.js on the frontend (NOT the backend's asyncpg URL).
AUTH_DATABASE_URL=postgresql://casaval:change-me-strong-password@postgres:5432/casaval

# --- Auth (Auth.js on the frontend; the API verifies the token it mints) ---
AUTH_SECRET=generate-with: openssl rand -base64 33
API_JWT_SECRET=generate-with: openssl rand -base64 33   # MUST be identical for frontend + backend
# Google OAuth client (Google Cloud Console). Authorized redirect URI:
#   https://casaval.eu/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxx
# Soft rollout: false = /enriched still accepts anonymous (IP-limited). Flip to true to require login.
REQUIRE_AUTH=false

# --- Email (Resend): email verification + password reset ---
RESEND_API_KEY=re_xxxx
EMAIL_FROM=Casaval <onboarding@resend.dev>   # switch to noreply@casaval.eu once the domain is verified

# --- Product analytics (PostHog EU) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_KEY=phc_xxxx                          # server-side (backend/worker); same project key is fine

# --- Error tracking (Sentry) ---
SENTRY_DSN=https://xxxx.ingest.de.sentry.io/xxxx              # backend + worker
NEXT_PUBLIC_SENTRY_DSN=https://xxxx.ingest.de.sentry.io/xxxx  # frontend

# Descriptive User-Agent with a contact — required by the OSM Nominatim usage policy.
NOMINATIM_USER_AGENT=pricemap-beta (you@example.com)

# Optional: raise if shared-NAT beta testers trip the per-IP limit (5/hour, 20/day).
# VALUATION_RATE_LIMIT_HOUR=5
# VALUATION_RATE_LIMIT_DAY=20
# Global daily spend ceiling (accepted valuations/day) — bounds Gemini/Nominatim cost.
# VALUATION_GLOBAL_DAILY_CAP=500
